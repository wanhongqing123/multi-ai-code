models/whisper/*.bin
resources/asr/**/bin/*
resources/asr/**/lib/*
resources/asr/**/licenses/*
!resources/asr/README.md
!resources/asr/**/.gitkeep

# Runtime AI CLI system-prompt injection files (never the user's content)
.injections/
