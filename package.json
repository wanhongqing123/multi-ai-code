{
  "name": "multi-ai-code",
  "version": "0.1.0",
  "description": "Multi-AI Code — 持续交付集成管理平台",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "icons": "node scripts/build-icons.mjs",
    "dist": "npm run icons && electron-vite build && electron-builder",
    "dist:mac": "npm run icons && electron-vite build && electron-builder --mac",
    "dist:win": "npm run icons && electron-vite build && electron-builder --win",
    "dist:all": "npm run icons && electron-vite build && electron-builder --mac --win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "postinstall": "electron-rebuild -f -o better-sqlite3,node-pty"
  },
  "dependencies": {
    "@xterm/addon-search": "^0.16.0",
    "better-sqlite3": "^11.3.0",
    "diff": "^9.0.0",
    "node-pty": "^1.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "build": {
    "appId": "com.multiaicode.app",
    "productName": "Multi-AI Code",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "electron/prompts/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Multi-AI Code ${version}",
      "artifactName": "MultiAICode-${version}-${arch}.dmg"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MultiAICode-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Multi-AI Code"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
