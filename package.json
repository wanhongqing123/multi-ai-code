{
  "name": "multi-ai-code",
  "version": "0.1.0",
  "description": "Multi-AI Code — 持续交付集成管理平台",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:aicli": "node scripts/build-aicli.mjs",
    "start": "electron-vite preview",
    "icons": "node scripts/build-icons.mjs",
    "prepare-asr": "node scripts/prepare-asr-assets.mjs",
    "dist": "npm run icons && npm run prepare-asr && electron-vite build && electron-builder",
    "dist:mac": "npm run icons && node scripts/prepare-asr-assets.mjs --target darwin-arm64 && electron-vite build && electron-builder --mac",
    "dist:win": "npm run icons && node scripts/prepare-asr-assets.mjs --target win32-x64 && electron-vite build && electron-builder --win",
    "dist:all": "npm run icons && npm run prepare-asr && electron-vite build && electron-builder --mac --win",
    "package:mac:electron": "scripts/package-macos-electron.sh",
    "package:mac:qt-im": "desktop/qt-im/scripts/package-macos.sh",
    "release:mac": "scripts/upload-macos-releases.sh",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json && node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:remote-im": "vitest run --exclude '.worktrees/**' electron/remote-im/*.test.ts src/remote-im/*.test.ts electron/preload.remoteIm.test.ts",
    "postinstall": "electron-rebuild -f -o better-sqlite3,node-pty"
  },
  "dependencies": {
    "@tencentcloud/lite-chat": "^4.4.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "better-sqlite3": "^11.3.0",
    "diff": "^9.0.0",
    "iconv-lite": "^0.6.3",
    "mermaid": "^11.15.0",
    "node-pty": "^1.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "build": {
    "appId": "com.multiaicode.app",
    "productName": "Multi-AI Code",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "bin/**/*",
      "electron/prompts/**/*",
      "build/icon-256.png",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/iconv-lite/**",
      "node_modules/node-pty/**",
      "node_modules/safer-buffer/**",
      "bin/**"
    ],
    "extraResources": [
      {
        "from": "resources/asr",
        "to": "asr"
      }
    ],
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Multi-AI Code ${version}",
      "icon": "build/icon.icns",
      "artifactName": "MultiAICode-${version}-${arch}.dmg"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MultiAICode-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Multi-AI Code"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
